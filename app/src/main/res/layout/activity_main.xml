<?xml version="1.0" encoding="utf-8"?>
<!-- Root dùng LinearLayout theo yêu cầu project -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:orientation="vertical">

    <!-- Màn Login -->
    <ScrollView
        android:id="@+id/loginScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="72dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_runna_wave" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/brand_name"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/welcome_back_ready"
                android:textColor="@color/runna_text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:text="@string/email_batbuoc"
                android:textColor="@color/runna_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
            <!-- điền mail bắt buộc -->

            <EditText
                android:id="@+id/loginEmailInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_email"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textColorHint="@color/runna_text_secondary"
                android:textSize="17sp" />
            <!-- ô nhập mail -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/password_batbuoc"
                android:textColor="@color/runna_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loginPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_password"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textColorHint="@color/runna_text_secondary"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/forgotPasswordText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="14dp"
                android:text="@string/forgot_password"
                android:textColor="@color/runna_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/showRegisterText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="@string/register_prompt"
                android:textAlignment="center"
                android:textColor="@color/runna_text_primary"
                android:textSize="16sp" />
            <!-- để giữa, chữ Register đang đổi màu cam bằng code -->

            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/login"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp" />
            <!-- nút login chính -->
        </LinearLayout>
    </ScrollView>

    <!-- Màn Register -->
    <ScrollView
        android:id="@+id/registerScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:id="@+id/backToLoginButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/create_account"
                android:textColor="@color/runna_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/start_running_journey"
                android:textColor="@color/runna_text_secondary" />

            <EditText
                android:id="@+id/registerNameInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_name"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary" />

            <EditText
                android:id="@+id/registerEmailInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_email"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary" />

            <EditText
                android:id="@+id/registerPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_create_password"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary" />

            <EditText
                android:id="@+id/registerConfirmPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_confirm_password"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary" />

            <Button
                android:id="@+id/createAccountButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/create_account"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </ScrollView>

    <!-- Màn nhập thông tin cá nhân sau khi register -->
    <ScrollView
        android:id="@+id/personalInfoScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/personal_information"
                android:textColor="@color/runna_text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/complete_profile_prompt"
                android:textColor="@color/runna_text_secondary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/personalNameInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_full_name"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/personalEmailInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:enabled="false"
                android:hint="@string/hint_email"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/personalAgeInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_age"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/personalGenderInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_gender"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/personalHeightInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_height_cm"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/personalWeightInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_weight_kg"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <Button
                android:id="@+id/completeProfileButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/continue_label"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Main app sau khi login thành công -->
    <LinearLayout
        android:id="@+id/appScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/homeScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/homeWelcomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_back_sample"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/homeSubtitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ready_next_run"
                        android:textColor="@color/runna_text_secondary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/homeStartRunningButton"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="@string/start_running"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="118dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_subtle"
                            android:gravity="center"
                            android:text="@string/total_distance_card"
                            android:textAlignment="center"
                            android:textColor="@color/runna_text_primary"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="118dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_subtle"
                            android:gravity="center"
                            android:text="@string/avg_pace_card"
                            android:textAlignment="center"
                            android:textColor="@color/runna_text_primary"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/recentActivityText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="22dp"
                        android:text="@string/recent_activity_text"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/startScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/start_running"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/choose_workout_type"
                        android:textColor="@color/runna_text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/typeEasy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/easy_run_desc"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/typeLong"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/long_run_desc"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/typeInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/interval_desc"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/typeWalking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/walking_desc"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/beginRunButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="@string/start_run"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="17sp" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/historyScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="invisible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/run_history"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/history_month"
                        android:textColor="@color/runna_text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/history_easy_item"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/history_long_item"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/profileScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="invisible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/profile_subtitle"
                        android:textColor="@color/runna_text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/profileInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="22dp"
                        android:text="@string/profile_info_sample"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/editProfileButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/edit_profile"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/appInfoButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/app_information"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/logoutButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_card_subtle"
                        android:padding="20dp"
                        android:text="@string/logout"
                        android:textColor="@color/runna_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@drawable/bg_nav"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/home"
                android:textColor="@color/runna_primary" />

            <TextView
                android:id="@+id/navStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/start"
                android:textColor="@color/runna_text_secondary" />

            <TextView
                android:id="@+id/navHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/history"
                android:textColor="@color/runna_text_secondary" />

            <TextView
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/profile"
                android:textColor="@color/runna_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Màn hình tracking -->
    <LinearLayout
        android:id="@+id/trackingScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="invisible">

        <TextView
            android:id="@+id/runTypeChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_margin="22dp"
            android:background="@drawable/bg_chip_soft"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="@string/run_type_easy" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginHorizontal="22dp"
            android:background="@drawable/bg_tracking_header"
            android:gravity="center"
            android:text="@string/live_route_map"
            android:textAlignment="center"
            android:textColor="@color/runna_text_primary" />

        <TextView
            android:id="@+id/trackingTimerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/timer_default"
            android:textColor="@color/runna_text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/trackingStatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/tracking_stats_default"
            android:textColor="@color/runna_text_secondary" />

        <Button
            android:id="@+id/pauseRunButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:text="@string/pause"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- Popup màn pause/ tạm dừng -->
    <LinearLayout
        android:id="@+id/pauseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/runna_overlay"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/run_paused"
                android:textColor="@color/runna_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pauseStatsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_soft"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/pause_stats_default"
                android:textColor="@color/runna_text_primary" />

            <Button
                android:id="@+id/resumeRunButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/resume"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/finishRunButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_outline"
                android:backgroundTint="@null"
                android:text="@string/finish_run"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Màn tổng kết sau buổi chạy -->
    <LinearLayout
        android:id="@+id/summaryScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_surface"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="invisible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_summary_header"
            android:gravity="center"
            android:text="@string/great_job"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/summaryStatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:padding="30dp"
            android:text="@string/summary_stats_default"
            android:textAlignment="center"
            android:textColor="@color/runna_text_primary" />

        <Button
            android:id="@+id/summaryDoneButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="80dp"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:text="@string/done"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- Popup hiện reset password nếu người dùng ấn quên mk -->
    <LinearLayout
        android:id="@+id/forgotPasswordOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/runna_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:orientation="vertical"
            android:padding="25dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_password"
                android:textColor="@color/runna_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/reset_password_prompt"
                android:textColor="@color/runna_text_secondary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/forgotPasswordEmailInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_email"
                android:paddingHorizontal="16dp"
                android:textColor="@color/runna_text_primary"
                android:textSize="17sp" />

            <Button
                android:id="@+id/sendResetButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/send_reset_link"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Popup edit profile -->
    <LinearLayout
        android:id="@+id/editProfileOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/runna_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="invisible">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bottom_sheet"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/edit_profile"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_full_name"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_name"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <EditText
                    android:id="@+id/editEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_email"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_email"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <EditText
                    android:id="@+id/editAgeInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_age"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_age"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <EditText
                    android:id="@+id/editGenderInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_gender"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_gender"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <EditText
                    android:id="@+id/editHeightInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_height_cm"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_height"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <EditText
                    android:id="@+id/editWeightInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_weight_kg"
                    android:paddingHorizontal="16dp"
                    android:text="@string/sample_weight"
                    android:textColor="@color/runna_text_primary"
                    android:textSize="17sp" />

                <Button
                    android:id="@+id/saveProfileButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    android:text="@string/save_changes"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="17sp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Popup app in4 -->
    <LinearLayout
        android:id="@+id/appInfoOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/runna_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_information"
                android:textColor="@color/runna_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_soft"
                android:padding="18dp"
                android:text="@string/app_info_text"
                android:textColor="@color/runna_text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/closeAppInfoButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="@string/close"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
